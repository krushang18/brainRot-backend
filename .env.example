MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>
MONGODB_DATABASE=BrainRot

JWT_SECRET=<generate-a-long-random-string>

BREVO_API_KEY=xkeysib-xxxxxxxxxxxx
BREVO_FROM_EMAIL=your-verified-email@gmail.com
BREVO_FROM_NAME=BrainRot

# Set this to your frontend machine's IP and port
FRONTEND_URL=https://<frontend-ip>:3000

COOKIE_SECURE=true

# Add all origins the frontend runs on (comma separated)
ALLOWED_ORIGINS=https://localhost:3000,https://<frontend-ip>:3000
